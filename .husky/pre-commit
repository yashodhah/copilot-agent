#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-commit hook: Block commit if a .env file is staged

echo "Checking for .env file in staged changes..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  echo "✓ No staged files to scan"
  exit 0
fi

for file in $STAGED_FILES; do
  # Only check files that exist (skip deleted files)
  if [ ! -f "$file" ]; then
    continue
  fi

  # If the file is exactly named ".env", block the commit
  if [ "$(basename "$file")" = ".env" ]; then
    echo "✗ .env file detected in staged changes: $file"
    echo "Please remove .env from staging and add it to your .gitignore."
    exit 1
  fi

done

echo "✓ No .env file detected"
exit 0
